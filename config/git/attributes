# Normalize text files in a sensible way
* text=auto

# Shell scripts should stay LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Source code: force LF to avoid cross-platform churn
*.c text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.hpp text eol=lf
*.hh text eol=lf
*.py text eol=lf
*.R text eol=lf
*.r text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
Makefile text eol=lf
